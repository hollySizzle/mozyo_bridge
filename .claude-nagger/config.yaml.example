# Claude Nagger main config skeleton.
#
# Copy this file to `.claude-nagger/config.yaml` and customise per
# project. Distributed by `mozyo-bridge scaffold apply redmine-governed`.
# Skip with `--skip-nagger` when the project does not use Claude Nagger.
#
# Claude Nagger is a project-local runtime guardrail that surfaces
# governance docs in front of Claude when it edits sensitive files.
# It does not enforce — it reminds. The catalog is the durable source
# of truth; this file controls runtime behaviour only.

version: 1

# Whether the nagger is active for this project. Set to false to
# disable runtime reminders without removing the config files.
enabled: true

# File-convention payload location. Generated by
# `mozyo-bridge docs generate-file-conventions` from the catalog.
# Do not edit by hand.
file_conventions: .claude-nagger/file_conventions.generated.yaml

# Severity → action mapping. Adjust per project.
severity:
  block: prompt   # surface message + require acknowledgement
  warn: notice    # surface message, do not block
  info: log       # log only

# Files that the nagger should treat as out-of-scope for reminders
# (already covered by other guardrails). Optional.
exclude_paths: []
