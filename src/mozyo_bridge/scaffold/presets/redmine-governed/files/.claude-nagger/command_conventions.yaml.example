# Claude Nagger command conventions skeleton.
#
# Copy this file to `.claude-nagger/command_conventions.yaml` and
# customise per project. The shipped skeleton lists only safe
# generic command patterns; replace with project-specific risky
# command guidance.
#
# Each entry attaches a message to a command pattern. The nagger
# surfaces the message before Claude runs a matching command so the
# operator can confirm the project rule before execution.

version: 1

rules:
  # Block destructive git operations until the operator confirms.
  - id: git-destructive
    name: git destructive operations
    patterns:
      - "git reset --hard*"
      - "git clean -fd*"
      - "git push --force*"
      - "git checkout -- *"
    severity: block
    message: >-
      Destructive git operation. Confirm the working tree state and
      uncommitted changes before running this command.

  # Warn on bulk file deletion.
  - id: rm-recursive
    name: recursive removal
    patterns:
      - "rm -rf*"
    severity: warn
    message: >-
      Recursive removal. Double-check the path before running.

  # Warn before routing an implementation request to the default-lane
  # Claude. Guardrail / scaffold / preset / workflow / release work should
  # have a recorded sublane dispatch decision first; sending such an
  # implementation request to the default-lane Claude without one is an
  # operational smell that loses sublane isolation and parallelism.
  - id: default-lane-implementation-handoff
    name: default-lane implementation handoff without dispatch decision
    patterns:
      - "mozyo-bridge handoff send --to claude * --kind implementation_request*"
      - "mozyo-bridge notify-claude*"
    severity: warn
    message: >-
      Default-lane Claude implementation handoff. For guardrail, scaffold,
      preset, workflow, or release implementation requests, confirm a Redmine
      dispatch decision exists before sending. Prefer sublane-first routing
      through the target lane Codex over a direct default-lane Claude handoff.
      If you intentionally choose default-lane implementation, record the
      exception reason in the Redmine issue.
