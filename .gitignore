.DS_Store

# Python caches and build outputs
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/
*.egg-info/
tmp/

# Virtual environments
.venv/
venv/

# Local-only docs catalog overlay (Redmine #11819). The public catalog
# stays free of private paths; this git-ignored overlay carries
# checkout-local docs that `mozyo-bridge docs resolve` / `audit-impact`
# merge when present. Never commit it.
.mozyo-bridge/docs/catalog.local.yaml

# Local secrets and release credentials
.env
.env.*
!.env.example
.pypirc

# VS Code extension PoC build outputs
experimental/**/node_modules/
experimental/**/out/
experimental/**/dist/
experimental/**/*.vsix
experimental/**/.vscode-test/
